NEXT_PUBLIC_SITE_URL=https://grounds.beamthinktank.space
NEXT_PUBLIC_BEAM_HOME_URL=https://home.beamthinktank.space
NEXT_PUBLIC_GROUNDS_COHORT_ID=cohort_beam_grounds_launch
NEXT_PUBLIC_GROUNDS_ORGANIZATION_ID=org_beam_grounds
NEXT_PUBLIC_GROUNDS_ENTRY_CHANNEL=grounds.beamthinktank.space
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated admin emails (gates the admin UI; keep in sync with firestore.rules).
# Defaults to ezra@beamthink.institute when unset.
NEXT_PUBLIC_ADMIN_EMAILS=ezra@beamthink.institute

# Civic open-data dataset ids (server-side) used by /api/civic to scan records.
# Milwaukee (data.milwaukee.gov runs CKAN) — set to the Master Property (MPROP) resource id.
CIVIC_MILWAUKEE_RESOURCE_ID=
