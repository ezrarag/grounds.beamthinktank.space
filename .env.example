NEXT_PUBLIC_SITE_URL=https://grounds.beamthinktank.space
NEXT_PUBLIC_BEAM_HOME_URL=https://home.beamthinktank.space
NEXT_PUBLIC_GROUNDS_COHORT_ID=cohort_beam_grounds_launch
NEXT_PUBLIC_GROUNDS_ORGANIZATION_ID=org_beam_grounds
NEXT_PUBLIC_GROUNDS_ENTRY_CHANNEL=grounds.beamthinktank.space
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated admin emails (gates the admin UI; keep in sync with firestore.rules).
# Defaults to ezra@beamthink.institute when unset.
NEXT_PUBLIC_ADMIN_EMAILS=ezra@beamthink.institute

# Civic open-data dataset ids (server-side) used by /api/civic to scan records.
# Each city needs its dataset/resource id before live scans return data.
# Milwaukee (data.milwaukee.gov runs CKAN) — Master Property (MPROP) resource id (UUID).
CIVIC_MILWAUKEE_RESOURCE_ID=

# Socrata cities share one optional app token (raises rate limits; not required).
CIVIC_SOCRATA_APP_TOKEN=
# Socrata dataset ids (the xxxx-xxxx id from the dataset's API endpoint).
CIVIC_NEW_YORK_RESOURCE_ID=
CIVIC_CHICAGO_RESOURCE_ID=
CIVIC_LOS_ANGELES_RESOURCE_ID=
CIVIC_SAN_FRANCISCO_RESOURCE_ID=
CIVIC_SEATTLE_RESOURCE_ID=

# Quick-add helpers.
# Google Maps key for address autocomplete (public) + Street View hero photos.
# GOOGLE_MAPS_SERVER_KEY is preferred for the server-side Street View proxy;
# it falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY if unset.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_KEY=
# Regrid nationwide parcel lookup (address → owner/zoning/parcel/value).
REGRID_API_TOKEN=
